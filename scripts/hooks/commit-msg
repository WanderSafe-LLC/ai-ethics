#!/bin/bash
# AI Ethics Commit Message Hook
# Prevents commits with AI attribution in messages
# Author: Victor J. Quiñones (FutureTranz)

set -e

COMMIT_MSG_FILE=$1

# Get the repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"
ENFORCER="$REPO_ROOT/src/ai_ethics_enforcer.py"

# Check if Python enforcer exists
if [ ! -f "$ENFORCER" ]; then
    echo "AI Ethics enforcer not found. Please run install script first."
    exit 1
fi

# Activate virtual environment if it exists
if [ -f "$REPO_ROOT/venv/bin/activate" ]; then
    source "$REPO_ROOT/venv/bin/activate"
fi

echo "🔍 Checking commit message for AI ethics violations..."

# Check commit message file
if ! python3 "$ENFORCER" --type file "$COMMIT_MSG_FILE" >/dev/null 2>&1; then
    echo "❌ AI Ethics violation found in commit message"
    echo "💡 Remove AI attribution from commit message"
    echo ""
    echo "Common violations:"
    echo "  - Co-authored-by: [AI tool name]"
    echo "  - Generated by [AI tool]"
    echo "  - Assisted by [AI tool]"
    echo ""
    echo "Reference: AI_ATTRIBUTION_POLICY.md"
    exit 1
fi

echo "✅ Commit message AI ethics check passed!"
exit 0
